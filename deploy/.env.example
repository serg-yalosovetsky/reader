# Пример конфигурации читалки. Скопируйте в корень как .env и заполните.
# Все переменные опциональны — есть разумные дефолты для локального запуска.

# Каталог рантайм-данных (БД, скачанные книги, ключ шифрования).
# READER_DATA_DIR=/opt/reader/data

# --- Calibre (этап 2) ---
# Вариант А: локальный calibredb на том же хосте (VPS).
# READER_CALIBREDB_BIN=calibredb
# READER_CALIBRE_LIBRARY=/path/to/Calibre Library
# Вариант Б: Calibre Content Server по сети.
# READER_CALIBRE_SERVER_URL=http://127.0.0.1:8080
# READER_CALIBRE_USERNAME=
# READER_CALIBRE_PASSWORD=

# --- ReadEra sync (этап 3) ---
# rclone-remote и путь к бэкапам ReadEra в Google Drive.
# READER_RCLONE_BIN=rclone
# READER_READERA_BACKUP_REMOTE=gdrive:ReadEra

# --- Скачивание (этап 2) ---
# READER_FICHUB_API=https://fichub.net/api/v0
# READER_DOWNLOAD_CONCURRENCY=1
